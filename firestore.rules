rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Checking if user is verified
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "saidsalum076660@gmail.com" || 
        request.auth.token.email == "admin@kingatv.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User document validation
    function isValidUser(user) {
      return user.uid == request.auth.uid 
        && user.email is string 
        && user.name is string 
        && user.name.size() <= 100
        && user.status in ["PENDING", "ACTIVE", "BLOCKED"]
        && user.freeSecondsRemaining is number
        && user.freeSecondsRemaining >= 0
        && user.freeSecondsRemaining <= 125;
    }

    // User collection rules
    match /users/{userId} {
      // Each user can ONLY read their own user data. They cannot read other users' data.
      allow get: if isOwner(userId) || isAdmin();
      
      // Listing all users is restricted to Admin only. Simple users have no access to listing.
      allow list: if isAdmin();
      
      // Each user can only write/create their own registered user document.
      allow create: if isOwner(userId) 
        && request.resource.data.uid == userId
        && request.resource.data.status == "PENDING"
        && request.resource.data.freeSecondsRemaining == 120
        && request.resource.data.createdAt != null;
        
      // Each user can only update their own user document. No other user can access or write to it.
      // Admins are permitted to perform administrative updates.
      allow update: if isSignedIn() && (
        isAdmin() || (
          isOwner(userId) 
          && request.resource.data.status == resource.data.status // cannot self-approve
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.freeSecondsRemaining is number
          && request.resource.data.freeSecondsRemaining <= resource.data.freeSecondsRemaining // countdown only
        )
      );
      
      // Standard users are completely blocked from deleting user records.
      allow delete: if isAdmin();
    }

    // Channels Collection - public read-only for authenticated system users, managed by admin
    match /channels/{channelId} {
      allow read: if isSignedIn();
      allow write, create, update, delete: if isAdmin();
    }

    // Slideshow Collection - public read-only for authenticated system users, managed by admin
    match /slideshow/{slideId} {
      allow read: if isSignedIn();
      allow write, create, update, delete: if isAdmin();
    }

    // Matches Collection - public read-only for authenticated system users, managed by admin
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write, create, update, delete: if isAdmin();
    }

    // Settings Collection (Global settings) - read-only for authenticated system users, managed by admin
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write, create, update: if isAdmin();
    }

    // Notifications Collection - read-only for authenticated system users, managed by admin
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write, create, update, delete: if isAdmin();
    }
  }
}
